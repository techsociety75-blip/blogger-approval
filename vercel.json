{
  "version": 2,
  "name": "blogger-approval-backend",
  "env": {
    "DATABASE_URL": "@blogger_approval_database_url",
    "JWT_SECRET": "@blogger_approval_jwt_secret",
    "JWT_REFRESH_SECRET": "@blogger_approval_jwt_refresh_secret",
    "NODE_ENV": "production",
    "LOG_LEVEL": "info",
    "GOOGLE_SHEETS_ID": "@google_sheets_id",
    "GOOGLE_SHEETS_CREDENTIALS": "@google_sheets_credentials"
  },
  "buildCommand": "npm ci --only=production",
  "devCommand": "npm run dev",
  "functions": {
    "src/app.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/app.js"
    }
  ]
}
